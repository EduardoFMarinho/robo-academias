# Ambiente da aplicacao: development, test ou production.
NODE_ENV=development

# Porta da API HTTP local.
APP_PORT=3000

# Host de bind da API. 0.0.0.0 permite acesso local e pela rede.
APP_HOST=0.0.0.0

# URL base da aplicacao. Use uma URL publica se quiser expor links fora da maquina.
APP_BASE_URL=http://localhost:3000

# Fuso usado no agendamento automatico.
APP_TIMEZONE=America/Sao_Paulo

# Token opcional para proteger o endpoint POST /api/scrape.
API_AUTH_TOKEN=

# Token do bot do Telegram criado no BotFather.
TELEGRAM_BOT_TOKEN=

# Lista opcional de chat IDs autorizados, separados por virgula.
TELEGRAM_ALLOWED_CHAT_IDS=

# Se true, abre o Chrome visivelmente para voce acompanhar o robo.
SCRAPER_SHOW_BROWSER=false

# Se true, roda em modo invisivel. Ignorado quando SCRAPER_SHOW_BROWSER=true.
SCRAPER_HEADLESS=true

# Pausa extra entre etapas do navegador, em milissegundos, para facilitar visualizacao.
SCRAPER_STEP_DELAY_MS=0

# Tempo maximo de espera do scraper por pagina ou elemento, em milissegundos.
SCRAPER_TIMEOUT_MS=20000

# Navegador usado pelo Selenium. Hoje o projeto suporta chrome.
SCRAPER_BROWSER=chrome

# Caminho opcional do executavel do Chrome, se voce quiser forcar um binario especifico.
CHROME_BINARY_PATH=

# Se true, faz uma varredura automatica assim que a aplicacao inicia.
SCRAPE_ON_START=false

# Expressao cron para executar varreduras automaticas.
SCRAPE_SCHEDULE=*/30 * * * *

# URL da pagina de planos da Smart Fit usada no scraping.
SMARTFIT_SOURCE_URL=https://www.smartfit.com.br/planos

# URL da unidade/pagina da Bluefit usada no scraping.
BLUEFIT_SOURCE_URL=https://www.bluefit.com.br/unidade/aclimacao

# Pasta onde o banco JSON e screenshots serao armazenados.
DATA_DIR=data

# Quantidade maxima de logs mantidos no banco local.
LOG_RETENTION_LIMIT=25
