{
  "name": "robo-academias",
  "version": "1.0.0",
  "private": true,
  "description": "Monitor de precos de academias com Selenium, API HTTP e bot do Telegram.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "scrape:once": "tsx src/cli/scrape-once.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "selenium-webdriver": "^4.43.0",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/selenium-webdriver": "^4.35.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
